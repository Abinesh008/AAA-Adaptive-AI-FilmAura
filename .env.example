# ==============================================================================
# AAA - Adaptive AI FilmAura: Environmental Configurations
# Copy this file to '.env' at the workspace root, backend/, or frontend/ as required.
# ==============================================================================

# --- Application Profile ---
APP_NAME="AAA - Adaptive AI FilmAura"
APP_ENV=development
DEBUG=True

# --- Relational Storage (PostgreSQL) ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=filmaura

# --- Graph Database (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Vector Database (ChromaDB) ---
CHROMA_PERSIST_DIR=data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Cache and Rate Limiting (Redis) ---
CACHE_PROVIDER=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Artificial Intelligence Providers ---
# Options: openai, gemini, mock
LLM_PROVIDER=mock
OPENAI_API_KEY=mock-openai-api-key
GEMINI_API_KEY=mock-gemini-api-key
LLM_MODEL=mock-model

# --- Embeddings Providers ---
# Options: local, openai, mock
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Third-party movie services metadata ---
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# --- Frontend Gateway ---
NEXT_PUBLIC_API_URL=http://localhost:8000
