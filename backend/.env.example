# ==============================================================================
# AAA - Adaptive AI FilmAura Environment Configuration Template
# ==============================================================================

# Application Configuration
APP_NAME="AAA - Adaptive AI FilmAura"
APP_ENV="development"
API_V1_STR="/api/v1"
DEBUG=true

# Database Configuration (PostgreSQL)
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="filmaura"

# Graph Database Configuration (Neo4j)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# Vector Database Configuration (ChromaDB)
# If CHROMA_HOST is set, will connect using HttpClient. Otherwise, falls back to PersistentClient.
CHROMA_PERSIST_DIR="data/chroma"
CHROMA_HOST=""
CHROMA_PORT=8000

# LLM Providers Configuration (options: openai, gemini, mock)
LLM_PROVIDER="openai"
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
LLM_MODEL="gpt-4o"

# Embedding Providers Configuration (options: local, openai, mock)
EMBEDDING_PROVIDER="local"
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"

# Cache Configuration (options: memory, redis)
CACHE_PROVIDER="memory"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
DEFAULT_CACHE_EXPIRE=3600

# Rate Limiter Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
